# ── Moment Track Configuration ──────────────────────────────
# Copy to .env and uncomment to customize.
# All variables use the MT_ prefix.

# Server
# MT_HOST=0.0.0.0
# MT_PORT=8000

# Data directory (database, exports, snapshots)
# MT_DATA_DIR=~/.mt_track

# Database URL (auto-computed from DATA_DIR if empty)
# MT_DB_URL=sqlite:///path/to/custom.db

# CORS origins (JSON array)
# MT_CORS_ORIGINS=["*"]

# API prefix
# MT_API_PREFIX=/api/v1

# Frontend dist directory
# MT_FRONTEND_DIST=./frontend/dist

# GPU Worker
# MT_WORKER_URL=http://127.0.0.1:8001
# MT_WORKER_TIMEOUT=2.0
# MT_WORKER_HOST=0.0.0.0
# MT_WORKER_PORT=8001

# Video encoding
# MT_JPEG_QUALITY=85

# SSE polling interval (seconds)
# MT_SSE_POLL_INTERVAL=1.0
